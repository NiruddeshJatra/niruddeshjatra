{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.niruddeshjatra.space"
        }
      ],
      "destination": "https://niruddeshjatra.space/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/games/arczero",
      "destination": "https://arczero.vercel.app/"
    },
    {
      "source": "/games/arczero/",
      "destination": "https://arczero.vercel.app/"
    },
    {
      "source": "/games/arczero/:path*",
      "destination": "https://arczero.vercel.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
